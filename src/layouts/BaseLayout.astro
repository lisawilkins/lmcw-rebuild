---
import '../styles/globals.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildJsonLdGraph } from '../utils/jsonLd';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/images/og/og-social.png',
  jsonLd = [],
  noIndex = false,
} = Astro.props;

const GA_ID = import.meta.env.PUBLIC_GA_ID ?? 'G-CMCEEBE9G8';
const jsonLdGraph = buildJsonLdGraph(jsonLd);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.lisawilkins.com${ogImage}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lisa Wilkins" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.lisawilkins.com${ogImage}`} />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />

    <!-- Google Analytics -->
    {GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-[var(--color-coral)] text-[var(--color-off-white)] px-4 py-2 rounded-md font-semibold z-50">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      const HEADER_OFFSET = 64;

      function closeMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const toggle = document.getElementById('mobile-menu-toggle');
        menu?.classList.add('hidden');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.setAttribute('aria-label', 'Open navigation menu');
      }

      function scrollToConnect(smooth = true) {
        const target = document.getElementById('connect');
        if (!target) return;

        const top = target.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
        window.scrollTo({ top: Math.max(0, top), behavior: smooth ? 'smooth' : 'auto' });
      }

      function navigateToConnect() {
        closeMobileMenu();

        if (window.location.hash !== '#connect') {
          history.replaceState(null, '', '#connect');
        }

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            scrollToConnect(true);

            // Lazy-loaded images below the fold can shift layout after the first scroll.
            [100, 300, 600, 1000].forEach((delay) => {
              window.setTimeout(() => scrollToConnect(false), delay);
            });
          });
        });
      }

      function initConnectNavigation() {
        document.querySelectorAll('a[href="#connect"]').forEach((link) => {
          if (link.dataset.connectNavInit === 'true') return;
          link.dataset.connectNavInit = 'true';
          link.addEventListener('click', (event) => {
            event.preventDefault();
            navigateToConnect();
          });
        });
      }

      initConnectNavigation();
      document.addEventListener('astro:page-load', initConnectNavigation);
    </script>
  </body>
</html>
