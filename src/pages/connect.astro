---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Lisa Wilkins",
    "jobTitle": "UX Director & Product Strategist",
    "description": "17+ year UX director, designer, and product strategist. Previously NBCUniversal, PragerU, Microsoft.",
    "url": "https://www.lisawilkins.com/connect",
    "email": "hello@lisawilkins.com",
    "sameAs": ["https://www.linkedin.com/in/lisawilkins"]
  }
};
---

<BaseLayout
  title="Connect — Lisa Wilkins"
  description="Let's talk about what Lisa Wilkins can build with your team. UX Director and Product Strategist with 17+ years of experience."
  ogImage="/og/connect.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <PageHero ariaLabelledby="leading-heading" bgColor="#ffffff">
    <h1 id="leading-heading" class="text-4xl md:text-6xl font-extrabold text-[var(--color-charcoal)] leading-tight mb-16 max-w-xl">
      Leading by example
    </h1>
    <div class="grid md:grid-cols-3 gap-10">
        <article>
          <h2 class="text-lg font-extrabold text-[var(--color-charcoal)] mb-3 uppercase tracking-wide">Allied Collaborator</h2>
          <p class="text-[var(--color-dark-gray)] leading-relaxed">
            I build trust through candid, proactive communication. Surfacing problems early keeps teams and their stakeholders informed and aligned.
          </p>
        </article>
        <article>
          <h2 class="text-lg font-extrabold text-[var(--color-charcoal)] mb-3 uppercase tracking-wide">Workflow Architect</h2>
          <p class="text-[var(--color-dark-gray)] leading-relaxed">
            I close skills gaps and redesign front- and backstage processes so teams can move fluidly. At PragerU, this reduced product delivery cycle time by 43%.
          </p>
        </article>
        <article>
          <h2 class="text-lg font-extrabold text-[var(--color-charcoal)] mb-3 uppercase tracking-wide">WCAG Advocate</h2>
          <p class="text-[var(--color-dark-gray)] leading-relaxed">
            Accessibility isn't a final checklist. I embed WCAG compliance from project kickoff. I led initiatives that improved accessibility scores from 55% to 85% across multiple platforms.
          </p>
        </article>
      </div>
  </PageHero>

  <!-- Hello / Bio / CTA -->
  <section class="bg-[var(--color-light-bg)] py-16 px-6" aria-labelledby="bio-heading">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-2xl">
        <h2 id="bio-heading" class="text-3xl md:text-4xl font-extrabold text-[var(--color-charcoal)] mb-8 leading-tight">
          Hello!
        </h2>
        <p class="text-base md:text-lg text-[var(--color-dark-gray)] leading-relaxed mb-10">
          I'm Lisa Wilkins. I've spent 17+ years as a UX director, designer, and product strategist building things people actually want to use — across media, news, tech, and education at organizations like NBCUniversal, PragerU, and Microsoft. I live in the Sonoran Desert, which inspires me daily with its simplicity on the surface and complexity underneath. I'm adaptable, resilient, and nerdy — ask me about WCAG compliance or horse training and you'll get the same enthusiasm. I'm most proud of raising a son full of gratitude and spoiling a very good dog.
        </p>
        <p class="text-lg font-semibold text-[var(--color-charcoal)] mb-8">
          Let's talk about what I can build with your team.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="mailto:hello@lisawilkins.com"
            class="inline-block bg-[var(--color-coral)] hover:bg-[var(--color-coral-hover)] text-white text-sm font-semibold uppercase tracking-widest px-8 py-4 rounded-md transition-colors"
          >
            hello@lisawilkins.com
          </a>
          <a
            href="https://www.linkedin.com/in/lisawilkins"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block border-2 border-[var(--color-charcoal)] hover:border-[var(--color-coral)] hover:text-[var(--color-coral)] text-[var(--color-charcoal)] text-sm font-semibold uppercase tracking-widest px-8 py-4 rounded-md transition-colors"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
