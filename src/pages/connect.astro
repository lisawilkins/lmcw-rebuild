---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ConnectSection from '../components/ConnectSection.astro';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Lisa Wilkins",
    "jobTitle": "UX Director & Product Strategist",
    "description": "17+ year UX director, designer, and product strategist. Previously NBCUniversal, PragerU, Microsoft.",
    "url": "https://www.lisawilkins.com/connect",
    "email": "hello@lisawilkins.com",
    "sameAs": ["https://www.linkedin.com/in/lisawilkins"]
  }
};
---

<BaseLayout
  title="Connect — Lisa Wilkins"
  description="Let's talk about what Lisa Wilkins can build with your team. UX Director and Product Strategist with 17+ years of experience."
  ogImage="/og/connect.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <PageHero ariaLabelledby="leading-heading" bgColor="#ffffff">
    <h1 id="leading-heading" class="text-4xl md:text-6xl font-extrabold text-[var(--color-charcoal)] leading-tight mb-16 max-w-xl">
      Leading by example
    </h1>
    <div class="grid md:grid-cols-3 gap-10">
        <article>
          <h2 class="text-lg font-extrabold text-[var(--color-charcoal)] mb-3 uppercase tracking-wide">Allied Collaborator</h2>
          <p class="text-[var(--color-dark-gray)] leading-relaxed">
            I build trust through candid, proactive communication. Surfacing problems early keeps teams and their stakeholders informed and aligned.
          </p>
        </article>
        <article>
          <h2 class="text-lg font-extrabold text-[var(--color-charcoal)] mb-3 uppercase tracking-wide">Workflow Architect</h2>
          <p class="text-[var(--color-dark-gray)] leading-relaxed">
            I close skills gaps and redesign front- and backstage processes so teams can move fluidly. At PragerU, this reduced product delivery cycle time by 43%.
          </p>
        </article>
        <article>
          <h2 class="text-lg font-extrabold text-[var(--color-charcoal)] mb-3 uppercase tracking-wide">WCAG Advocate</h2>
          <p class="text-[var(--color-dark-gray)] leading-relaxed">
            Accessibility isn't a final checklist. I embed WCAG compliance from project kickoff. I led initiatives that improved accessibility scores from 55% to 85% across multiple platforms.
          </p>
        </article>
      </div>
  </PageHero>

  <ConnectSection />
</BaseLayout>
