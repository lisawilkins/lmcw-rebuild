---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="NBC App Redesign — Lisa Wilkins"
  description="How Lisa Wilkins architected component systems and content frameworks for NBC News, TODAY, and Telemundo supporting 1.5M+ daily users across two full app redesigns."
  ogImage="/og/nbc-news.png"
>
  <!-- Page header -->
  <section class="bg-[var(--color-charcoal)] pt-20 pb-16 px-6" aria-labelledby="page-heading">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-coral)] mb-4">NBC News</p>
      <h1 id="page-heading" class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-6 max-w-2xl">
        Building for scale &amp; flexibility
      </h1>
      <p class="text-lg text-gray-400 max-w-xl">
        NBCUniversal · NBC News, TODAY, Telemundo · UX Director
      </p>
    </div>
  </section>

  <!-- Lead -->
  <section class="bg-white py-16 px-6">
    <div class="max-w-5xl mx-auto max-w-2xl">
      <p class="text-xl md:text-2xl font-semibold text-[var(--color-charcoal)] leading-relaxed mb-6">
        Solutions for NOW are valuable. Solutions for LATER pay you back.
      </p>
      <p class="text-base md:text-lg text-[var(--color-dark-gray)] leading-relaxed">
        At NBCUniversal, I architected component systems and content frameworks across NBC News, TODAY, and Telemundo that supported 1.5M+ daily users, and kept scaling through two full app redesigns with a flexible foundation. That meant understanding the tech stack deeply enough to design for future growth.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-[var(--color-coral)] py-10 px-6" aria-label="Key outcomes">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-3 gap-8">
      <div class="text-white text-center">
        <p class="text-4xl md:text-5xl font-extrabold leading-none mb-2">1.5M+</p>
        <p class="text-sm font-semibold uppercase tracking-widest opacity-80">Daily active users</p>
      </div>
      <div class="text-white text-center">
        <p class="text-4xl md:text-5xl font-extrabold leading-none mb-2">2</p>
        <p class="text-sm font-semibold uppercase tracking-widest opacity-80">Full app redesigns</p>
      </div>
      <div class="text-white text-center col-span-2 md:col-span-1">
        <p class="text-4xl md:text-5xl font-extrabold leading-none mb-2">3</p>
        <p class="text-sm font-semibold uppercase tracking-widest opacity-80">Brands served</p>
      </div>
    </div>
  </section>

  <!-- Main content area — to be filled with full case study -->
  <section class="bg-white py-16 px-6">
    <div class="max-w-5xl mx-auto max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] mb-6">Full case study</p>
      <p class="text-base md:text-lg text-[var(--color-dark-gray)] leading-relaxed">
        Case study content for the NBC App Redesign will be added here. This section is ready to receive the full narrative, images, process documentation, and outcomes from the Figma file.
      </p>
    </div>
  </section>

  <!-- Back nav -->
  <section class="bg-[var(--color-light-bg)] py-10 px-6">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="text-sm font-semibold text-[var(--color-mid-gray)] hover:text-[var(--color-coral)] transition-colors">
        &larr; Back to home
      </a>
      <a href="/strategy" class="text-sm font-semibold text-[var(--color-mid-gray)] hover:text-[var(--color-coral)] transition-colors">
        Strategy &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
