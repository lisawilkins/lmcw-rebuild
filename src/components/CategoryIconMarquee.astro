---
import { responsiveWebp } from '../utils/responsiveWebp';

interface Icon {
  /** WebP folder under /images/strategy/, e.g. strat_puf_cat_amval */
  folder?: string;
  /** PNG fallback when no WebP folder exists */
  src?: string;
  alt: string;
}

interface Props {
  icons: Icon[];
}

const { icons } = Astro.props;
// Duplicate for a longer scroll range through the full set
const trackIcons = [...icons, ...icons];
---

<div
  class="category-marquee"
  data-category-marquee
  role="list"
  aria-label="PragerU content category icons"
>
  <div class="category-marquee-track">
    {
      trackIcons.map((icon, i) => {
        const { folder, src: pngSrc, alt } = icon;
        const webp = folder ? responsiveWebp('strategy', folder) : null;
        return (
          <figure class="category-marquee-card" role="listitem">
            <img
              src={webp?.src ?? pngSrc}
              srcset={webp?.srcset}
              alt={i < icons.length ? alt : ''}
              aria-hidden={i >= icons.length}
              loading="lazy"
            />
          </figure>
        );
      })
    }
  </div>
</div>

<style>
  .category-marquee {
    position: relative;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    margin-bottom: 4rem;
  }

  .category-marquee-track {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 8px;
    width: max-content;
    will-change: transform;
  }

  .category-marquee-card {
    flex: 0 0 auto;
    margin: 0;
    max-height: 80px;
  }

  @media (min-width: 768px) {
    .category-marquee-card {
      max-height: 100px;
    }
  }

  @media (min-width: 1024px) {
    .category-marquee-card {
      max-height: 160px;
    }
  }

  .category-marquee-card img {
    display: block;
    width: auto;
    height: auto;
    max-height: 80px;
    border-radius: 0.5rem;
  }

  @media (min-width: 768px) {
    .category-marquee-card img {
      max-height: 100px;
    }
  }

  @media (min-width: 1024px) {
    .category-marquee-card img {
      max-height: 160px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .category-marquee-track {
      transform: none !important;
      overflow-x: auto;
      width: 100%;
      padding-inline: 1.5rem;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .category-marquee {
      overflow-x: auto;
    }

    .category-marquee-card {
      scroll-snap-align: start;
    }
  }
</style>

<script>
  function initCategoryMarquee() {
    const wrap = document.querySelector<HTMLElement>('[data-category-marquee]');
    const track = wrap?.querySelector<HTMLElement>('.category-marquee-track');
    if (!wrap || !track) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let ticking = false;

    const update = () => {
      const rect = wrap.getBoundingClientRect();
      const vh = window.innerHeight;
      const scrollRange = (vh + rect.height) * 1.82;
      const scrolled = vh - rect.top;
      const progress = Math.min(1, Math.max(0, scrolled / scrollRange));

      const maxShift = Math.max(0, track.scrollWidth - wrap.clientWidth);
      track.style.transform = `translate3d(${-progress * maxShift}px, 0, 0)`;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  initCategoryMarquee();
  document.addEventListener('astro:page-load', initCategoryMarquee);
</script>
