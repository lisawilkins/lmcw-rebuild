---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-charcoal)] text-[var(--color-white)]">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
      <!-- Brand -->
      <div class="flex flex-col gap-3 max-w-xs">
        <a href="/" class="font-extrabold text-lg tracking-tight hover:text-[var(--color-coral)] transition-colors">
          LW
        </a>
        <p class="text-sm text-[var(--color-mid-gray)] leading-relaxed">
          Helping teams and companies achieve their maximum potential.
        </p>
      </div>

      <!-- Nav -->
      <nav aria-label="Footer navigation" class="flex flex-col gap-3">
        <a href="/" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-white)] transition-colors">Home</a>
        <a href="/projects-nbcapp" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-white)] transition-colors">NBC News</a>
        <a href="/projects-puf" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-white)] transition-colors">Strategy</a>
        <a href="#connect" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-white)] transition-colors">Connect</a>
      </nav>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border)] text-xs text-[var(--color-mid-gray)]">
      &copy; {year} Lisa Wilkins. All rights reserved.
    </div>
  </div>
</footer>
