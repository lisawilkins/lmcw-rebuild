---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-charcoal)] text-[var(--color-off-white)]">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <a href="/" aria-label="Lisa Wilkins — home" class="block w-[32px] hover:opacity-80 transition-opacity">
          <svg width="916" height="958" viewBox="0 0 916 958" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
            <path d="M802.645 691.191C780.288 714.137 710.909 846.203 486.391 853.197C263.072 853.197 104.588 685.305 104.588 461.687C104.588 256.906 248.837 97.6237 486.483 97.6237C723.022 97.6237 817.665 279.436 817.665 279.436L758.853 513.396L711.924 285.415H639.246L568.713 513.35L490.221 285.345H419.411L365.883 572.861H282.107V285.345H198.516V650.54H435.077L466.987 463.072L533.62 650.978H603.829L669.078 462.195L701.795 651.024L792.424 651.879C792.424 651.879 909.078 281.606 909.078 277.289C909.078 254.99 779.869 6.92529 487.106 6.92529C204.584 6.92529 13.8438 230.866 13.8438 473.229C13.8438 732.928 213.767 948.766 486.391 948.766C700.065 948.766 816.766 815.085 868.632 752.065L802.645 691.191Z" fill="var(--color-primary)"/>
          </svg>
        </a>
        <p class="text-sm text-[var(--color-mid-gray)] leading-relaxed whitespace-nowrap">
          Helping teams and companies achieve their maximum potential.
        </p>
      </div>

      <!-- Nav -->
      <nav aria-label="Footer navigation" class="flex flex-col gap-3">
        <a href="/" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-off-white)] transition-colors">Home</a>
        <a href="/projects-nbcapp" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-off-white)] transition-colors">NBC News</a>
        <a href="/projects-puf" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-off-white)] transition-colors">Strategy</a>
        <a href="#connect" class="text-sm font-semibold uppercase tracking-widest text-[var(--color-mid-gray)] hover:text-[var(--color-off-white)] transition-colors">Connect</a>
      </nav>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border)] text-xs text-[var(--color-mid-gray)]">
      &copy; {year} Lisa Wilkins. All rights reserved.
    </div>
  </div>
</footer>
