---
/**
 * ConnectSection — bio + contact links.
 * Repeated at the bottom of every page; the global nav "CONNECT" item
 * links to the #connect anchor.
 *
 * Background: var(--color-blue-800) + desert photo at 20% opacity.
 * Layout: "Hello!" + square bio pic on the left, copy + links on the right.
 * Stacks vertically on mobile.
 */
---

<section
  id="connect"
  class="relative overflow-hidden"
  aria-labelledby="connect-heading"
>

  <!-- ── Background ─────────────────────────────────────────────── -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-[var(--color-blue-800)]"></div>
    <img
      src="/images/home/connect-bg-01.png"
      alt=""
      class="absolute inset-0 w-full h-full max-w-none object-cover opacity-20"
    />
  </div>

  <!-- ── Content ────────────────────────────────────────────────── -->
  <div class="relative flex items-center justify-center py-[60px] px-5 md:p-[80px] lg:py-[130px] lg:px-[100px]">
    <div class="flex flex-col md:flex-row gap-[40px] items-center md:items-start w-full max-w-[850px]">

      <!-- Left: Hello! + bio pic -->
      <div class="flex flex-col gap-5 items-center shrink-0 w-[160px] md:w-auto md:max-w-[180px] lg:max-w-[200px]">
        <h2
          id="connect-heading"
          class="font-light leading-[0.85] text-[var(--color-cream)] text-[60px] whitespace-nowrap self-start"
        >
          Hello!
        </h2>
        <div class="w-full aspect-square rounded-[8px] overflow-hidden">
          <img
            src="/images/home/connect-bio-pic-01.png"
            alt="Lisa Wilkins"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <!-- Right: copy + links -->
      <div class="flex flex-col gap-5 text-[var(--color-off-white)] flex-1 min-w-0">

        <!-- Bio paragraphs -->
        <div class="flex flex-col gap-3 text-[16px] md:text-[20px] leading-[1.45]">
          <p>
            I'm Lisa Wilkins. I've spent 17+ years as a UX director, designer, and product strategist building things people actually want to use — across media, news, tech, and education at organizations like NBCUniversal, PragerU, and Microsoft. I live in the Sonoran Desert, which inspires me daily with its simplicity on the surface and complexity underneath. I'm adaptable, resilient, and nerdy — ask me about WCAG compliance or horse training and you'll get the same enthusiasm. I'm most proud of raising a son full of gratitude and spoiling a very good dog.
          </p>
          <p>
            Let's talk about what I can build with your team.
          </p>
        </div>

        <!-- Contact links -->
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-5 font-semibold text-[20px] md:text-[24px] leading-none">
          <a
            href="mailto:hello@lisawilkins.com"
            class="underline underline-offset-4 decoration-2 whitespace-nowrap hover:text-[var(--color-cream)] transition-colors"
            aria-label="Send an email"
          >
            hello@lisawilkins.com
          </a>
          <span class="hidden md:inline" aria-hidden="true">•</span>
          <a
            href="https://www.linkedin.com/in/lisamwilkins/"
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-4 decoration-2 whitespace-nowrap hover:text-[var(--color-cream)] transition-colors"
            aria-label="Visit my LinkedIn profile"
          >
            LinkedIn
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
