---
/**
 * PhotosSection — "Things I've seen" gallery with lightbox.
 * Thumbnails use square crops (*_sq); tap/click opens the full numbered image.
 */
import { PHOTOS, photoSrc, photoSrcset } from '../data/photos';
---

<section
  id="photos"
  class="photos-section bg-[var(--color-blue-900)] py-[60px] md:py-[80px] lg:py-[100px] px-5 md:px-8 lg:px-10"
  aria-labelledby="photos-heading"
>
  <h2
    id="photos-heading"
    class="font-light leading-none text-[var(--color-cream)] text-[36px] md:text-[44px] lg:text-[52px] text-center mb-8 md:mb-10 lg:mb-12"
  >
    Things I've seen
  </h2>

  <div class="photos-grid mx-auto w-full max-w-[1440px]">
    {
      PHOTOS.map((photo) => (
        <button
          type="button"
          class="photo-thumb group relative aspect-square overflow-hidden rounded-[var(--radius-md)] cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-coral)]"
          data-photo-id={photo.id}
          data-full-src={photoSrc(photo.folder, photo.prefix)}
          data-full-srcset={photoSrcset(photo.folder, photo.prefix)}
          aria-label={`View photo ${Number(photo.id)}`}
        >
          <img
            src={photoSrc(photo.sqFolder, photo.sqPrefix, '2x')}
            srcset={photoSrcset(photo.sqFolder, photo.sqPrefix)}
            alt=""
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-[1.03]"
          />
        </button>
      ))
    }
  </div>
</section>

<div
  id="photo-lightbox"
  class="photo-lightbox"
  hidden
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <button
    type="button"
    class="photo-lightbox__backdrop"
    aria-label="Close photo viewer"
    tabindex="-1"
  ></button>

  <div class="photo-lightbox__content">
    <button
      type="button"
      id="photo-lightbox-close"
      class="photo-lightbox__close"
      aria-label="Close photo viewer"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    <img
      id="photo-lightbox-image"
      class="photo-lightbox__image"
      src=""
      srcset=""
      alt=""
    />
  </div>
</div>

<style>
  .photos-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--spacing-2);
  }

  @media (min-width: 640px) {
    .photos-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: var(--spacing-2);
    }
  }

  @media (min-width: 1024px) {
    .photos-grid {
      grid-template-columns: repeat(10, minmax(0, 1fr));
      gap: var(--spacing-2);
    }
  }

  .photo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-6);
  }

  .photo-lightbox[hidden] {
    display: none;
  }

  .photo-lightbox__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgb(11 18 20 / 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
    opacity: 0;
  }

  .photo-lightbox.is-open .photo-lightbox__backdrop {
    animation: photo-lightbox-backdrop-in 240ms ease-out forwards;
  }

  .photo-lightbox__content {
    position: relative;
    z-index: 1;
    max-width: min(92vw, 1200px);
    max-height: 90vh;
    pointer-events: none;
  }

  .photo-lightbox__close {
    position: absolute;
    top: -2.75rem;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-off-white);
    cursor: pointer;
    pointer-events: auto;
    opacity: 0;
    transition: opacity 150ms ease;
  }

  .photo-lightbox.is-open .photo-lightbox__close {
    animation: photo-lightbox-close-in 200ms ease-out 120ms forwards;
  }

  .photo-lightbox__close:hover {
    opacity: 0.75;
  }

  .photo-lightbox__image {
    display: block;
    max-width: min(92vw, 1200px);
    max-height: 85vh;
    width: auto;
    height: auto;
    border-radius: var(--radius-md);
    object-fit: contain;
    pointer-events: auto;
    transform: scale(0.82);
    opacity: 0;
    transform-origin: center center;
  }

  .photo-lightbox.is-open .photo-lightbox__image {
    animation: photo-lightbox-zoom-in 320ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes photo-lightbox-zoom-in {
    from {
      opacity: 0;
      transform: scale(0.82);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes photo-lightbox-backdrop-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes photo-lightbox-close-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-lightbox.is-open .photo-lightbox__backdrop,
    .photo-lightbox.is-open .photo-lightbox__image,
    .photo-lightbox.is-open .photo-lightbox__close {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function initPhotoLightbox() {
    const lightbox = document.getElementById('photo-lightbox');
    const lightboxImage = document.getElementById('photo-lightbox-image') as HTMLImageElement | null;
    const closeButton = document.getElementById('photo-lightbox-close');
    const backdrop = lightbox?.querySelector<HTMLButtonElement>('.photo-lightbox__backdrop');

    if (!lightbox || !lightboxImage || !closeButton || !backdrop) return;
    if (lightbox.dataset.init === 'true') return;
    lightbox.dataset.init = 'true';

    let lastFocused: HTMLElement | null = null;

    function openLightbox(trigger: HTMLButtonElement) {
      const src = trigger.dataset.fullSrc ?? '';
      const srcset = trigger.dataset.fullSrcset ?? '';
      const photoId = trigger.dataset.photoId ?? '';

      lightboxImage.src = src;
      if (srcset) {
        lightboxImage.srcset = srcset;
      } else {
        lightboxImage.removeAttribute('srcset');
      }
      lightboxImage.alt = photoId ? `Photo ${Number(photoId)}` : 'Photo';

      lastFocused = trigger;
      lightbox.classList.remove('is-open');
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          lightbox.classList.add('is-open');
        });
      });

      closeButton.focus();
    }

    function closeLightbox() {
      lightbox.classList.remove('is-open');
      lightbox.hidden = true;
      document.body.style.overflow = '';
      lightboxImage.removeAttribute('srcset');
      lightboxImage.src = '';
      lastFocused?.focus();
      lastFocused = null;
    }

    document.querySelectorAll<HTMLButtonElement>('.photo-thumb').forEach((thumb) => {
      if (thumb.dataset.lightboxInit === 'true') return;
      thumb.dataset.lightboxInit = 'true';
      thumb.addEventListener('click', () => openLightbox(thumb));
    });

    closeButton.addEventListener('click', closeLightbox);
    backdrop.addEventListener('click', closeLightbox);

    lightboxImage.addEventListener('click', (event) => {
      event.stopPropagation();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !lightbox.hidden) {
        closeLightbox();
      }
    });
  }

  initPhotoLightbox();
  document.addEventListener('astro:page-load', initPhotoLightbox);
</script>
