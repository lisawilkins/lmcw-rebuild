---
import { webpBackgroundImageSet, type ImageRoot } from '../utils/responsiveWebp';

interface Props {
  ariaLabelledby: string;
  bgColor?: string;
  bgImage?: string;
  /** WebP folder name under /images/{root}/, e.g. nbc_bg_heading */
  bgImageWebpFolder?: string;
  bgImageWebpRoot?: ImageRoot;
  imageOpacity?: number;
  minHeight?: string;
  gradientFade?: boolean;
  scrimColor?: string;
  grayscale?: boolean;
}

const {
  ariaLabelledby,
  bgColor = 'var(--color-off-white)',
  bgImage,
  bgImageWebpFolder,
  bgImageWebpRoot = 'nbc',
  imageOpacity = 0.4,
  minHeight = '320px',
  gradientFade = false,
  scrimColor,
  grayscale = false,
} = Astro.props;

const fadeColor = scrimColor ?? bgColor;
const bgImageStyle =
  bgImage && bgImageWebpFolder
    ? webpBackgroundImageSet(bgImageWebpRoot, bgImageWebpFolder, bgImage)
    : bgImage
      ? `url('${bgImage}')`
      : undefined;
---

<section
  class="relative flex flex-col overflow-hidden"
  style={`background-color: ${bgColor}; min-height: ${minHeight}`}
  aria-labelledby={ariaLabelledby}
>
  {bgImage && (
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat pointer-events-none"
      style={`background-image: ${bgImageStyle}; opacity: ${imageOpacity}; filter: ${grayscale ? 'grayscale(100%)' : 'none'}`}
      aria-hidden="true"
    />
  )}
  {gradientFade && (
    <div
      class="absolute inset-0 pointer-events-none"
      style={`background: linear-gradient(to bottom, transparent 30%, ${fadeColor} 90%)`}
      aria-hidden="true"
    />
  )}
  <div class="relative mt-auto max-w-[1080px] mx-auto w-full px-6 pb-10">
    <slot />
  </div>
</section>
